AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Analytics tracking (both optional)
GA4_MEASUREMENT_ID=      # e.g. G-XXXXXXXXXX — enables full event tracking in dashboard HTML
TRACKING_PIXEL_URL=      # e.g. https://your-server/pixel.gif — enables open tracking in email HTML
GA4_API_SECRET=
# API mode (optional — only needed when using --api flag)
FLOWACE_API_TOKEN=        # Authorization header value for getDailywiseTimesheet
FLOWACE_API_URL=https://api.flowace.in/prod

# Sharing (optional — only needed when using --share flag)
S3_BUCKET=                # S3 bucket name for presigned dashboard links